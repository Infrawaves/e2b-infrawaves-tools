# Grafana / Prometheus dev 环境
# 真实凭证写到 .env(已在 .gitignore 中),不要提交本仓库

GRAFANA_URL=http://grafana.example.com:3000
GRAFANA_USER=admin
GRAFANA_PASS=changeme

# Grafana 中的 Prometheus 数据源名称(scripts/sync-grafana*.{sh,py} 通过名称反查 UID)
DS_NAME=prometheus
# scripts/sync-grafana.sh 推送 dashboard 时使用的文件夹标题
FOLDER=e2b
# scripts/sync-grafana-alerts.py 推送告警时使用的文件夹标题
ALERT_FOLDER=e2b-alerts

PROM_URL=http://prom.example.com:9090

# 用于 dashboard 变量 $node_ip 的示例值(任一 dev 节点 IP)
NODE_IP_SAMPLE=10.0.0.1
