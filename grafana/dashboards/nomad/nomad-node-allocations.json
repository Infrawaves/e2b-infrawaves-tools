          "max": 100,
          "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
      "id": 3,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "nomad_allocation_memory_usage_percentage{node_name=~\"$node_name\"}",
          "legendFormat": "{{node_name}} / {{job_name}}",
          "refId": "A"
        }
      ],
      "title": "分配内存使用率(阈值 80/90)",
