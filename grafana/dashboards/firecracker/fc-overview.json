  "description": "Firecracker process-level metrics from nomad-nodeJob-exporter (e2b_fc_*).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Number of nomad-nodeJob-exporter targets currently DOWN. Red = at least one exporter unreachable, visibility lost on that node.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "red", "value": 1}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 10,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "11.3.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "count(up{job=\"nomad-nodeJob-exporter\"} == 0) OR on() vector(0)",
          "refId": "A"
        }
      ],
      "title": "Exporter 离线",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Distinct nodes that reported firecracker processes in the selected window. If this drops, some node went silent.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red"}, {"color": "green", "value": 1}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "11.3.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "count(count by (node_ip) (e2b_fc_process_count{node_ip=~\"$node_ip\"}))",
          "refId": "A"
        }
      ],
      "title": "上报节点数",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green"}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "11.3.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(e2b_fc_process_count{node_ip=~\"$node_ip\"})",
          "refId": "A"
        }
      ],
      "title": "Firecracker 进程总数",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Cumulative cmdline parse failures. Sustained increase means exporter cannot extract sandbox_id; leak detection is degraded.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "red", "value": 1}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "11.3.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(e2b_fc_process_parse_errors_total{node_ip=~\"$node_ip\"})",
          "refId": "A"
        }
      ],
      "title": "Sandbox-ID 解析错误",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "processes",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": {"mode": "normal"}
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "id": 4,
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "e2b_fc_process_count{node_ip=~\"$node_ip\"}",
          "legendFormat": "{{node_ip}}",
          "refId": "A"
        }
      ],
      "title": "各节点 Firecracker 进程数",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisLabel": "bytes", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1},
          "unit": "bytes"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 5,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (node_ip) (e2b_fc_process_memory_hugetlb_bytes{node_ip=~\"$node_ip\"})",
          "legendFormat": "{{node_ip}}",
          "refId": "A"
        }
      ],
      "title": "各节点 HugeTLB 内存",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Aggregated CPU usage per node, in cores (1.0 = one full CPU core busy on firecracker processes).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisLabel": "cores", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1},
          "unit": "none"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 6,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (node_ip) (rate(e2b_fc_process_cpu_seconds_total{node_ip=~\"$node_ip\"}[5m]))",
          "legendFormat": "{{node_ip}}",
          "refId": "A"
        }
      ],
      "title": "各节点 CPU 用量(核)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Top nodes by total HugeTLB bytes consumed by firecracker processes. Outlier rows = candidates for leak / hot-spot.",
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "displayMode": "auto"},
          "unit": "bytes"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "id": 11,
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "hugetlb_bytes", "desc": true}]
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "topk(10, sum by (node_ip) (e2b_fc_process_memory_hugetlb_bytes{node_ip=~\"$node_ip\"}))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "HugeTLB 占用 Top 10 节点",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true},
            "renameByName": {"Value": "hugetlb_bytes"}
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Top nodes by firecracker process count. Outlier = scheduling skew or stuck node.",
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "displayMode": "auto"},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "id": 12,
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "fc_processes", "desc": true}]
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "topk(10, sum by (node_ip) (e2b_fc_process_count{node_ip=~\"$node_ip\"}))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Firecracker 进程数 Top 10 节点",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true},
            "renameByName": {"Value": "fc_processes"}
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "displayMode": "auto"},
          "unit": "bytes"
        }
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 28},
      "id": 7,
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "hugetlb_bytes", "desc": true}]
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "topk(50, e2b_fc_process_memory_hugetlb_bytes{node_ip=~\"$node_ip\"})",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "HugeTLB 占用 Top 50 沙箱",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true},
            "renameByName": {"Value": "hugetlb_bytes"}
          }
        }
      ],
      "type": "table"
    }
  ],
